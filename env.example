# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# PayPal Configuration
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here

# Email Configuration (Gmail)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# Next.js Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here

# Production URLs
NEXT_PUBLIC_SITE_URL=https://pro11.no

# Admin (server-only — never commit a real password)
# Generate a strong value, e.g. openssl rand -base64 24
# In Vercel: Settings → Environment Variables → add ADMIN_PASSWORD and enable "Sensitive"
# If you ever used the old example password (pro11admin2025), rotate it in Vercel immediately.
ADMIN_PASSWORD=change_me_use_a_long_random_password

# Vercel Cron (keeps Supabase free tier active — ping Mon/Thu 08:00 UTC)
# Generate a random string, e.g. openssl rand -hex 32
CRON_SECRET=your_random_cron_secret_here